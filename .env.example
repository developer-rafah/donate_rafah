# -----------------------------------------------------------------------------
# Rafd — environment variables
# Copy this file to .env.local for local development.
# NEVER commit real values. NEVER expose SUPABASE_SERVICE_ROLE_KEY to the client.
# -----------------------------------------------------------------------------

# --- Supabase (public, safe to expose) ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-only, NEVER prefix with NEXT_PUBLIC_) ------------------
# Used exclusively by server-side code paths that require elevated privileges.
# Must never be imported from a client component or exposed in a browser bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ----------------------------------------------------------------------
# Base URL of the deployed app. Used by server-side helpers where required.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Logging -----------------------------------------------------------------
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
